# Base de datos (Supabase — connection pooler)
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Conexión directa para prisma migrate
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # openssl rand -base64 32

# Supabase Storage
SUPABASE_URL="https://[ref].supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_KEY=""

# Resend (emails confirmación reservas)
RESEND_API_KEY=""

# WhatsApp Business — número sin + ni espacios (ej: 34999999999)
# Activa WhatsApp Business en el número del restaurante:
#   1. Descarga "WhatsApp Business" en móvil/tablet
#   2. Registra el número 934 65 30 00 (recibes código por llamada de voz)
#   3. Una vez activo, los usuarios podrán escribirte desde la web
# Para envíos automáticos del menú del día consulta: https://business.whatsapp.com/products/platform
NEXT_PUBLIC_WA_NUMBER="34999999999"
